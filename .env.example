# Copiază acest fișier în `.env` și schimbă valorile.
#   cp .env.example .env
# .env NU se comite (e în .gitignore).

# Portul serverului
PORT=3000

# Credențialele de admin (login real)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=schimba-ma-cu-o-parola-buna

# Secret pentru semnarea cookie-ului de sesiune — pune ceva lung și aleator.
# Generează unul: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=pune-aici-un-secret-lung-si-aleator

# Telefon de contact afișat în header/footer (opțional)
SITE_PHONE=+34 911 234 567

# --- Persistență durabilă cu Supabase Postgres (pentru Vercel) ---
# Connection string din Supabase → Project Settings → Database → Connection
# string → "Transaction pooler" (recomandat pe serverless, portul 6543).
# Dacă e setat: baza rulează în memorie și se sincronizează cu Postgres.
# Dacă NU e setat: local folosește SQLite pe disc; pe Vercel, memorie efemeră.
# DATABASE_URL=postgresql://postgres.xxxx:PAROLA@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# (opțional) câte conexiuni pg per instanță serverless (implicit 1)
# PG_POOL_MAX=1

# --- Doar pentru rulare locală pe disc (fără Supabase) ---
# DB_PATH=server/data.db
# UPLOADS_DIR=uploads
